# Oculus v4 Configuration File
# Copy to ~/.config/oculus/config.yaml

# General settings
threads: 50
timeout: 300
rate_limit: 150
retry_count: 2
retry_delay: 5
# Default timeout used by generic shell-invocations when a module doesn't pass its own timeout
default_timeout: 300

# SQLMap defaults (per-scan settings). You can override these per-scan via the web UI or API.
sqlmap:
  level: 5       # SQLMap "level" (1-5) — aggression of tests
  risk: 3        # SQLMap "risk" (1-3) — riskier payloads at higher values
  threads: 10    # SQLMap internal worker threads (maximum allowed by SQLMap is 10)
parallel: true        # Run independent tools concurrently
auto_confirm: false   # Skip confirmation prompts (useful for automation)
jitter: false         # Add random delays between tool calls for stealth

# Wordlist paths
wordlists:
  dns: /usr/share/wordlists/seclists/Discovery/DNS/subdomains-top1million-5000.txt
  dirs: /usr/share/wordlists/seclists/Discovery/Web-Content/common.txt
  dirs_fallback: /usr/share/wordlists/dirb/common.txt
  resolvers: /opt/recontools/massdns/resolvers.txt

# API Keys (optional — enables passive recon and 100x subdomain yield)
api_keys:
  shodan: ""            # Active Shodan API Key (Module 28)
  github: ""            # GitHub Classic/Fine-grained PAT with repo read scope (Module 26)
  chaos: ""             # ProjectDiscovery Chaos API Key (Subfinder / DNS resolution)
  virustotal: ""        # VirusTotal Passive API Key (Subfinder)
  securitytrails: ""    # SecurityTrails Enterprise/Free API Key (Subfinder - highly recommended)
  censys_id: ""         # Censys Search API ID (Subfinder)
  censys_secret: ""     # Censys Search API Secret (Subfinder)
  binaryedge: ""        # BinaryEdge API Key (Subfinder)
  intelx: ""            # IntelligenceX API Key (Subfinder)

# Nuclei configuration
nuclei:
  severity: low,medium,high,critical
  rate_limit: 150
  concurrency: 25
  templates: ""   # Custom template path (leave empty for defaults)

# Naabu port scanner
naabu:
  ports: "1-65535"
  rate: 2000

# FFUF directory fuzzing
ffuf:
  extensions: php,html,js,json,txt,bak,old
  status_filter: "200,204,301,302,307,401,403"
  recursion_depth: 2
